---
import PageLayout from "@layouts/PageLayout.astro";
import { useTranslations, getTranslation } from "@utils/i18n";
import { paintings, getPaintingThumbnail, getPaintingFull } from "@utils/paintingsData";

const lang = "en";
const t = useTranslations(lang);

const paintingItems = paintings.map((p) => ({
  ...p,
  title: getTranslation(lang, `painting.${p.id}.title`),
  description: getTranslation(lang, `painting.${p.id}.description`),
  thumbnailSrc: getPaintingThumbnail(p.id),
  fullSrc: getPaintingFull(p.id),
}));

const manifesto = t("paintings.manifesto.body");
const contactHref = "/en/contact";
---

<PageLayout metadata={{ title: t("paintings.title") }}>
  <div style="background: rgba(11,9,8,0.85); min-height: 100vh;">
    <div class="mx-auto px-6 md:px-16" style="max-width: 1440px; padding-top: 64px; padding-bottom: 80px;">
      <div class="text-center intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style="margin-bottom: 48px;">
        <p class="section-label" style="margin: 0 0 12px;">Goldenberry</p>
        <h1 class="serif" style="font-size: clamp(2.25rem, 4vw, 3rem); font-weight: 700; margin: 0 0 12px; color: #E8E0D2;">{t("paintings.title")}</h1>
        <p style="font-size: 1rem; color: #847B6F;">{t("paintings.subtitle")}</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px;">
        {paintingItems.map((p) => p.thumbnailSrc ? (
          <div class="painting-card" data-full={p.fullSrc} data-title={p.title} data-description={p.description} data-price={p.price} data-dimensions={`${p.height} × ${p.width} cm`} data-technique={p.technique} data-year={p.year}
            style="background: #1A1714; overflow: hidden; cursor: pointer; transition: transform 0.3s, box-shadow 0.3s;">
            <div style="aspect-ratio: 0.85; overflow: hidden;">
              <img src={p.thumbnailSrc} alt={p.title} width="600" height="700" class="painting-thumb-img" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;" loading="lazy" />
            </div>
            <div style="padding: 14px 16px 18px;">
              <p style="font-size: 0.875rem; font-weight: 600; margin: 0 0 4px; line-height: 1.3; color: #E8E0D2;">{p.title}</p>
              <p style="font-size: 0.75rem; color: #5E574E; margin: 0 0 6px;">{p.height} × {p.width} cm · {p.technique}</p>
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 1rem; font-weight: 700; color: #C47D3F;">USD {p.price}</span>
                <span style="font-size: 0.75rem; color: #5E574E;">{p.year}</span>
              </div>
            </div>
          </div>
        ) : null)}
      </div>
      {manifesto && (
        <div class="intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style="background: #1A1714; border: 1px solid #2C2620; padding: 36px 40px; margin-top: 56px;">
          <p class="section-label" style="margin: 0 0 14px;">{t("paintings.manifesto.title")}</p>
          <p style="font-size: 0.875rem; line-height: 1.8; color: #847B6F; margin: 0;">{manifesto}</p>
        </div>
      )}
    </div>
  </div>

  <div id="painting-lightbox" class="painting-lightbox-overlay">
    <div class="painting-lightbox-container">
      <button id="plb-close" class="plb-close" aria-label="Close">×</button>
      <button id="plb-prev" class="plb-nav plb-prev" aria-label="Previous"></button>
      <button id="plb-next" class="plb-nav plb-next" aria-label="Next"></button>
      <div class="plb-inner">
        <div class="plb-image-wrap"><img id="plb-image" class="plb-image" alt="" /></div>
        <div class="plb-info">
          <h2 id="plb-title" class="plb-title serif"></h2>
          <p id="plb-description" class="plb-description"></p>
          <div class="plb-meta">
            <div class="plb-meta-row"><span class="plb-meta-label">{t("paintings.price")}</span><span id="plb-price" class="plb-meta-value" style="color: #C47D3F; font-weight: 700; font-size: 1rem;"></span></div>
            <div class="plb-meta-row"><span class="plb-meta-label">{t("paintings.dimensions")}</span><span id="plb-dims" class="plb-meta-value"></span></div>
            <div class="plb-meta-row"><span class="plb-meta-label">{t("paintings.technique")}</span><span id="plb-tech" class="plb-meta-value"></span></div>
            <div class="plb-meta-row"><span class="plb-meta-label">{t("paintings.year")}</span><span id="plb-year" class="plb-meta-value"></span></div>
          </div>
          <a id="plb-contact" href={contactHref} class="plb-contact-btn">{t("paintings.contact-cta")}</a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .painting-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.35) !important; }
    .painting-card:hover .painting-thumb-img { transform: scale(1.05); }
    .painting-lightbox-overlay { position: fixed; inset: 0; background: transparent; z-index: 1000; display: flex; justify-content: center; align-items: center; opacity: 0; visibility: hidden; transition: all 0.3s ease; }
    .painting-lightbox-overlay.active { background: rgba(0,0,0,0.92); opacity: 1; visibility: visible; }
    .painting-lightbox-container { position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
    .plb-inner { display: flex; align-items: flex-start; gap: 2rem; max-width: 90vw; max-height: 90vh; transform: scale(0.9); opacity: 0; transition: all 0.35s ease; }
    .painting-lightbox-overlay.active .plb-inner { transform: scale(1); opacity: 1; }
    .plb-image-wrap { flex: 0 0 auto; }
    .plb-image { max-width: 55vw; max-height: 80vh; object-fit: contain; border-radius: 4px; box-shadow: 0 25px 50px rgba(0,0,0,0.6); }
    .plb-info { flex: 1; min-width: 260px; max-width: 320px; color: #E8E0D2; display: flex; flex-direction: column; gap: 1rem; max-height: 80vh; overflow-y: auto; }
    .plb-title { font-size: 1.375rem; font-weight: 700; line-height: 1.3; color: #E8E0D2; }
    .plb-description { font-size: 0.875rem; line-height: 1.7; color: #847B6F; }
    .plb-meta { border-top: 1px solid #2C2620; padding-top: 12px; display: flex; flex-direction: column; gap: 8px; }
    .plb-meta-row { display: flex; justify-content: space-between; font-size: 0.75rem; }
    .plb-meta-label { color: #5E574E; }
    .plb-meta-value { color: #E8E0D2; font-weight: 500; }
    .plb-contact-btn { display: block; text-align: center; padding: 10px 20px; background: #C47D3F; color: #fff; border-radius: 4px; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: background 0.2s; margin-top: auto; }
    .plb-contact-btn:hover { background: #D4924F; }
    .plb-close { position: fixed; top: 24px; right: 28px; background: none; border: none; font-size: 2.25rem; color: #E8E0D2; cursor: pointer; z-index: 1001; opacity: 0; transform: translateY(-15px); transition: all 0.25s ease 0.1s; }
    .painting-lightbox-overlay.active .plb-close { opacity: 1; transform: translateY(0); }
    .plb-close:hover { color: #C47D3F; }
    .plb-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(44,38,32,0.7); border: 1px solid #2C2620; font-size: 0; line-height: 1; color: #E8E0D2; cursor: pointer; z-index: 1001; width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center; opacity: 0; transition: all 0.25s ease 0.15s; }
    .painting-lightbox-overlay.active .plb-nav { opacity: 1; }
    .painting-lightbox-overlay.active .plb-nav:hover { background: rgba(196,125,63,0.25); border-color: #C47D3F; }
    .plb-prev { left: 16px; }
    .plb-next { right: 16px; }
    .plb-prev::before { content: ''; display: block; width: 10px; height: 10px; border-left: 2px solid #E8E0D2; border-bottom: 2px solid #E8E0D2; transform: rotate(45deg) translateX(2px); }
    .plb-next::before { content: ''; display: block; width: 10px; height: 10px; border-right: 2px solid #E8E0D2; border-bottom: 2px solid #E8E0D2; transform: rotate(-45deg) translateX(-2px); }
    @media (max-width: 768px) {
      .plb-inner { flex-direction: column; align-items: center; max-width: 92vw; gap: 1rem; padding-bottom: 1rem; }
      .plb-image { max-width: 88vw; max-height: 45vh; }
      .plb-info { min-width: unset; max-width: 88vw; max-height: 35vh; }
    }
  </style>
  <script>
    let plbAbort: AbortController | null = null;
    function initLightbox() {
      if (plbAbort) plbAbort.abort();
      plbAbort = new AbortController();
      const signal = plbAbort.signal;
      const cards = Array.from(document.querySelectorAll<HTMLElement>('.painting-card'));
      const overlay = document.getElementById('painting-lightbox');
      if (!overlay || !cards.length) return;
      const img = document.getElementById('plb-image') as HTMLImageElement;
      const titleEl = document.getElementById('plb-title')!;
      const descEl = document.getElementById('plb-description')!;
      const priceEl = document.getElementById('plb-price')!;
      const dimsEl = document.getElementById('plb-dims')!;
      const techEl = document.getElementById('plb-tech')!;
      const yearEl = document.getElementById('plb-year')!;
      let current = 0;
      function update() { const d = cards[current].dataset; img.src = d.full ?? ''; img.alt = d.title ?? ''; titleEl.textContent = d.title ?? ''; descEl.textContent = d.description ?? ''; priceEl.textContent = 'USD ' + (d.price ?? ''); dimsEl.textContent = d.dimensions ?? ''; techEl.textContent = d.technique ?? ''; yearEl.textContent = d.year ?? ''; }
      function open(i: number) { current = i; update(); overlay.classList.add('active'); document.body.style.overflow = 'hidden'; }
      function close() { overlay.classList.remove('active'); setTimeout(() => { document.body.style.overflow = ''; }, 300); }
      cards.forEach((c, i) => c.addEventListener('click', () => open(i), { signal }));
      document.getElementById('plb-close')!.addEventListener('click', close, { signal });
      document.getElementById('plb-prev')!.addEventListener('click', () => { current = (current - 1 + cards.length) % cards.length; update(); }, { signal });
      document.getElementById('plb-next')!.addEventListener('click', () => { current = (current + 1) % cards.length; update(); }, { signal });
      overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); }, { signal });
      document.addEventListener('keydown', (e) => {
        if (!overlay.classList.contains('active')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowRight') { current = (current + 1) % cards.length; update(); }
        if (e.key === 'ArrowLeft') { current = (current - 1 + cards.length) % cards.length; update(); }
      }, { signal });
    }
    initLightbox();
    document.addEventListener('astro:page-load', initLightbox);
  </script>
</PageLayout>
