---
import Hero from "@components/Hero.astro";
import Steps from "@components/Steps.astro";
import CallToAction from "@components/CallToAction.astro";
import Layout from "@layouts/PageLayout.astro";

import { getContentProjects, getExtraWorksImages } from "@utils/projectsData";
import { paintings, getPaintingThumbnail } from "@utils/paintingsData";
import { useTranslations, getTranslation } from "@utils/i18n";

const lang = "en";
const t = useTranslations(lang);

const metadata = {
  title: t("site.title"),
  description: t("site.description"),
  canonical: "https://maximiliano-neira.com/en/",
};

const ContentProjects = getContentProjects(t, lang);
const extraWorksImages = getExtraWorksImages();

const featuredPaintings = paintings
  .filter((p) => p.featured)
  .map((p) => ({
    ...p,
    title: getTranslation(lang, `painting.${p.id}.title`),
    thumbnail: getPaintingThumbnail(p.id),
  }));

const paintingsHref = "/en/paintings";
const contactHref = "/en/contact";

const skills = [
  {
    title: t("skills.art-direction.title"),
    desc: t("skills.art-direction.description"),
    color: "#D4AF37",
  },
  {
    title: t("skills.model-design.title"),
    desc: t("skills.model-design.description"),
    color: "#B89020",
  },
  {
    title: t("skills.cinematography.title"),
    desc: t("skills.cinematography.description"),
    color: "#847B6F",
  },
];
---

<Layout metadata={metadata}>
  <Hero
    id="hero"
    title={t("hero.name")}
    subtitle={t("hero.subtitle")}
    image={{
      src: "https://res.cloudinary.com/ds8bhx4d4/image/upload/q_auto,f_auto/profile_npqqoy",
      alt: "Portrait of Maximiliano Neira, art director and filmmaker",
      width: 600,
      height: 800,
    }}
  >
    <Fragment slot="paragraph">{t("hero.description")}</Fragment>
    <Fragment slot="actions">
      <a
        href={`https://maxistorage.blob.core.windows.net/assets/cv/CV-EN.pdf`}
        download="CV-Maximiliano-Neira-EN.pdf"
        target="_blank"
        class="hero-btn-primary"
      >
        {t("hero.download-cv")}
      </a>
      <a href="#porfolio" class="hero-btn-tertiary">
        {t("nav.portfolio")}
      </a>
    </Fragment>
  </Hero>

  <section
    id="about"
    style="background: rgba(11,9,8,0.85); padding: 80px clamp(24px, 4vw, 64px);"
  >
    <div class="mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style="max-width: 1440px;">
      <!-- Label + Heading -->
      <div style="margin-bottom: 40px;">
        <p class="section-label" style="margin: 0 0 12px;">About me</p>
        <h2 class="serif" style="font-size: clamp(1.5rem, 2.8vw, 2.25rem); font-weight: 700; margin: 0; line-height: 1.1; color: #E8E0D2;">
          {t("about.heading") || "Aesthetics"} as <span style="color: #D4AF37;">{t("about.heading-accent") || "language"}</span>
        </h2>
      </div>
      <!-- Two columns: Text (left) | Video (right) -->
      <div class="about-content" style="display: flex; gap: 48px; flex-wrap: wrap; margin-bottom: 56px; align-items: center;">
        <div style="flex: 1; min-width: 280px; display: flex; flex-direction: column; gap: 20px;">
          <p style="font-size: 1rem; line-height: 1.8; color: #847B6F; margin: 0;">{t("about.description")}</p>
          <p style="font-size: 1rem; line-height: 1.8; color: #847B6F; margin: 0;">{t("about.description-2")}</p>
        </div>
        <div style="flex: 1; min-width: 280px; display: flex; align-items: flex-start;">
          <div style="border-radius: 8px; overflow: hidden; width: 100%; max-width: 560px;">
            <video class="w-full" style="display: block; border-radius: 8px;" controls muted playsinline preload="metadata" data-preview-start="3">
              <source src="https://res.cloudinary.com/ds8bhx4d4/video/upload/f_mp4,q_auto/video-profile_ejrrej" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px;">
        {skills.map((s) => (
          <div class="skill-card intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style={`padding: 28px 24px; background: #1A1714; border-radius: 10px; border-top: 3px solid ${s.color}; transition: background 0.25s, transform 0.25s;`}>
            <h3 class="serif" style="font-size: 1.25rem; font-weight: 700; margin: 0 0 10px; color: #E8E0D2;">{s.title}</h3>
            <p style="font-size: 1rem; line-height: 1.7; color: #847B6F; margin: 0;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Steps
    id="resume"
    title={t("experience.title")}
    items={[
      { title: `${t("experience.student.title")} <br /><span class="font-normal serif" style="color:#D4AF37; font-size: 0.875rem;">${t("experience.student.company")}</span> <br /><span class="font-normal" style="color:#5E574E; font-size: 0.75rem; letter-spacing:0.1em; text-transform:uppercase;">${t("experience.student.period")}</span>`, description: `${t("experience.student.description")} · <a href="https://www.arcos.cl/carreras/cine/" target="_blank" style="color:#D4AF37;">arcos.cl</a>`, icon: "tabler:school" },
      { title: `${t("experience.casa-hojas.title")} <br /><span class="font-normal serif" style="color:#D4AF37; font-size: 0.875rem;">${t("experience.casa-hojas.project")}</span> <br /><span class="font-normal" style="color:#5E574E; font-size: 0.75rem; letter-spacing:0.1em; text-transform:uppercase;">${t("experience.casa-hojas.period")}</span>`, description: t("experience.casa-hojas.description"), icon: "tabler:palette" },
      { title: `${t("experience.ciudad-latente.title")} <br /><span class="font-normal serif" style="color:#D4AF37; font-size: 0.875rem;">${t("experience.ciudad-latente.project")}</span> <br /><span class="font-normal" style="color:#5E574E; font-size: 0.75rem; letter-spacing:0.1em; text-transform:uppercase;">${t("experience.ciudad-latente.period")}</span>`, description: t("experience.ciudad-latente.description"), icon: "tabler:building-estate" },
      { title: `${t("experience.inhumano.title")} <br /><span class="font-normal serif" style="color:#D4AF37; font-size: 0.875rem;">${t("experience.inhumano.project")}</span> <br /><span class="font-normal" style="color:#5E574E; font-size: 0.75rem; letter-spacing:0.1em; text-transform:uppercase;">${t("experience.inhumano.period")}</span>`, description: t("experience.inhumano.description"), icon: "tabler:movie" },
      { title: `${t("experience.retrato-oval.title")} <br /><span class="font-normal serif" style="color:#D4AF37; font-size: 0.875rem;">${t("experience.retrato-oval.project")}</span> <br /><span class="font-normal" style="color:#5E574E; font-size: 0.75rem; letter-spacing:0.1em; text-transform:uppercase;">${t("experience.retrato-oval.period")}</span>`, description: t("experience.retrato-oval.description"), icon: "tabler:brush" },
    ]}
    classes={{ container: "max-w-3xl" }}
  />

  <!-- Paintings Preview -->
  <section
    id="paintings"
    style="background: rgba(11,9,8,0.85); padding: 80px clamp(24px, 4vw, 64px);"
  >
    <div class="mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style="max-width: 1440px;">
      <div style="margin-bottom: 36px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
          <span class="accent-line"></span>
          <span style="font-size: 0.75rem; letter-spacing: 0.08em; color: #D4AF37; font-weight: 500;">Goldenberry</span>
        </div>
        <h2 class="serif" style="font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 600; margin: 0; color: #E8E0D2;">{t("paintings.home-section-title")}</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
        {featuredPaintings.map((p) => p.thumbnail ? (
          <a href={paintingsHref} class="painting-thumb" style="display: block; background: #1A1714; border-radius: 8px; overflow: hidden; text-decoration: none;">
            <div style="aspect-ratio: 1; overflow: hidden;">
              <img src={p.thumbnail} alt={p.title} width="400" height="400" class="w-full h-full object-cover painting-thumb-img" loading="lazy" />
            </div>
            <div style="padding: 14px 16px 16px;">
              <p style="font-size: 0.875rem; font-weight: 500; margin: 0 0 6px; color: #E8E0D2;">{p.title}</p>
              <div style="display: flex; justify-content: space-between;">
                <span style="font-size: 1rem; font-weight: 700; color: #D4AF37;">USD {p.price}</span>
                <span style="font-size: 0.75rem; color: #5E574E;">{p.year}</span>
              </div>
            </div>
          </a>
        ) : null)}
      </div>
      <div style="display: flex; justify-content: center; margin-top: 36px;">
        <a href={paintingsHref} class="hero-btn-primary">{t("paintings.view-all")} →</a>
      </div>
    </div>
  </section>

  <section id="porfolio" style="background: rgba(11,9,8,0.85); padding: 80px clamp(24px, 4vw, 64px);">
    <div class="mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style="max-width: 1440px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
        <span class="accent-line"></span>
        <span style="font-size: 0.75rem; letter-spacing: 0.08em; color: #D4AF37; font-weight: 500;">Portfolio</span>
      </div>
      <h2 class="serif" style="font-size: clamp(2.25rem, 3.5vw, 3rem); font-weight: 600; color: #E8E0D2; margin: 0 0 48px;">{t("portfolio.title")}</h2>
      <div class="portfolio-grid">
        {ContentProjects.map((p) => (
          <a href={p.href} class="project-card" style="position: relative; border-radius: 8px; overflow: hidden; display: block; height: 320px; text-decoration: none;">
            <img src={p.image.src} alt={p.image.alt} width={p.image.width} height={p.image.height} class="w-full h-full object-cover project-img" loading="lazy" transition:name={`image-${p.id}`} />
            <div class="project-overlay" style="position: absolute; inset: 0; background: linear-gradient(180deg, transparent 20%, rgba(11,9,8,0.85) 60%, rgba(11,9,8,0.97) 100%); transition: background 0.3s;"></div>
            <div class="project-info" style="position: absolute; bottom: 0; left: 0; right: 0; padding: 24px 28px;">
              <h3 class="serif" style="font-size: 1.5rem; font-weight: 600; margin: 0; color: #D4AF37; line-height: 1.2;" set:html={p.projectTitleHTML} />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="background: rgba(11,9,8,0.85); padding: 80px clamp(24px, 4vw, 64px);">
    <div class="mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style="max-width: 1440px;">
      <p class="section-label" style="margin: 0 0 14px;">{t("other-works.title")}</p>
      <div class="accent-line" style="margin-bottom: 40px;"></div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
        {extraWorksImages.map((image, index) => (
          <div class="other-work-img gallery-image" data-index={index} style="aspect-ratio: 16/10; overflow: hidden; border-radius: 4px; cursor: pointer;">
            <img src={image.src} alt={image.alt} width={image.width || 1200} height={image.height || 800} class="w-full h-full object-cover other-img" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction
    title={t("cta.title")}
    subtitle={t("cta.subtitle")}
    actions={[{ variant: "primary", text: t("cta.button"), href: contactHref }]}
  />

  <div id="lightbox" class="lightbox-overlay">
    <div class="lightbox-container">
      <button id="lightbox-close" class="lightbox-close" aria-label="Close">×</button>
      <button id="lightbox-prev" class="lightbox-nav lightbox-prev" aria-label="Previous"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
      <button id="lightbox-next" class="lightbox-nav lightbox-next" aria-label="Next"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
      <img id="lightbox-image" class="lightbox-image" alt="" />
      <div class="lightbox-counter">
        <span id="lightbox-current">1</span> / <span id="lightbox-total">{extraWorksImages.length}</span>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-btn-primary { display: inline-flex; align-items: center; padding: 12px 28px; background: #D4AF37; color: #fff; font-size: 0.875rem; font-weight: 500; border-radius: 4px; text-decoration: none; transition: all 0.25s ease; }
  .hero-btn-primary:hover { background: #E0C040; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(212,175,55,0.3); }
  .hero-btn-secondary { display: inline-flex; align-items: center; padding: 12px 28px; background: transparent; color: #847B6F; font-size: 0.875rem; font-weight: 500; border: 1px solid #2C2620; border-radius: 4px; text-decoration: none; transition: all 0.25s ease; }
  .hero-btn-secondary:hover { color: #E8E0D2; border-color: #5E574E; }
  .hero-btn-tertiary { display: inline-flex; align-items: center; padding: 12px 28px; background: transparent; color: #D4AF37; font-size: 0.875rem; font-weight: 500; border: 1px solid #D4AF37; border-radius: 4px; text-decoration: none; transition: all 0.25s ease; }
  .hero-btn-tertiary:hover { background: rgba(212,175,55,0.1); }
  .skill-card:hover { background: #221F1A !important; transform: translateY(-2px); }
  .portfolio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 768px) { .portfolio-grid { grid-template-columns: 1fr; } }
  .project-img { transition: transform 0.6s ease; }
  .project-card:hover .project-img { transform: scale(1.05); }
  .project-card:hover .project-overlay { background: linear-gradient(180deg, transparent 20%, rgba(11,9,8,0.92) 65%, rgba(11,9,8,0.99) 100%) !important; }
  .project-info { transition: transform 0.3s ease; }
  .project-card:hover .project-info { transform: translateY(-4px); }
  .painting-thumb { transition: transform 0.3s; }
  .painting-thumb:hover { transform: translateY(-3px); }
  .painting-thumb-img { transition: transform 0.5s; }
  .painting-thumb:hover .painting-thumb-img { transform: scale(1.06); }
  .other-img { transition: transform 0.5s; }
  .other-work-img:hover .other-img { transform: scale(1.05); }
  .lightbox-overlay { position: fixed; inset: 0; background: transparent; z-index: 1000; display: flex; justify-content: center; align-items: center; opacity: 0; visibility: hidden; transition: all 0.3s ease; }
  .lightbox-overlay.active { background: rgba(0,0,0,0.92); opacity: 1; visibility: visible; }
  .lightbox-container { position: relative; width: 100vw; height: 100vh; display: flex; justify-content: center; align-items: center; }
  .lightbox-image { max-width: 70vw; max-height: 70vh; object-fit: contain; border-radius: 8px; transform: scale(0.85); opacity: 0; transition: all 0.35s ease; }
  .lightbox-overlay.active .lightbox-image { transform: scale(1); opacity: 1; }
  .lightbox-close { position: fixed; top: 24px; right: 28px; background: none; border: none; font-size: 2.5rem; color: #E8E0D2; cursor: pointer; z-index: 1001; opacity: 0; transform: translateY(-15px); transition: all 0.25s ease 0.1s; }
  .lightbox-overlay.active .lightbox-close { opacity: 1; transform: translateY(0); }
  .lightbox-close:hover { color: #D4AF37; }
  .lightbox-nav { position: fixed; top: 50%; transform: translateY(-50%); background: rgba(44,38,32,0.7); border: 1px solid #2C2620; font-size: 0; line-height: 1; color: #E8E0D2; cursor: pointer; z-index: 1001; width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center; opacity: 0; transition: all 0.25s ease 0.15s; }
  .lightbox-overlay.active .lightbox-nav { opacity: 1; }
  .lightbox-nav:hover { background: rgba(212,175,55,0.25); border-color: #D4AF37; }
  .lightbox-prev { left: 16px; }
  .lightbox-next { right: 16px; }

  .lightbox-counter { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px); color: #847B6F; font-size: 0.875rem; background: rgba(11,9,8,0.85); padding: 8px 16px; border-radius: 20px; border: 1px solid #2C2620; opacity: 0; transition: all 0.3s ease 0.15s; }
  .lightbox-overlay.active .lightbox-counter { opacity: 1; transform: translateX(-50%) translateY(0); }
  @media (max-width: 768px) {
    [style*="grid-template-columns: repeat(3, 1fr)"] { grid-template-columns: repeat(2, 1fr) !important; }
    .lightbox-image { max-width: 88vw; max-height: 60vh; }
    .lightbox-prev { left: 8px; }
    .lightbox-next { right: 8px; }
  }
</style>

<script define:vars={{ images: extraWorksImages }}>
  function initHomeLightbox() {
    if (window._homeLbAbort) window._homeLbAbort.abort();
    window._homeLbAbort = new AbortController();
    const { signal } = window._homeLbAbort;

    let currentIdx = 0;
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxCurrent = document.getElementById("lightbox-current");
    const lightboxTotal = document.getElementById("lightbox-total");
    if (!lightbox) return;
    if (lightboxTotal) lightboxTotal.textContent = images.length;
    document.querySelectorAll(".gallery-image").forEach((el) => {
      el.addEventListener("click", () => {
        currentIdx = parseInt(el.getAttribute("data-index") || "0");
        updateImage();
        lightbox.classList.add("active");
        document.body.style.overflow = "hidden";
      }, { signal });
    });
    function updateImage() {
      if (!lightboxImage || !lightboxCurrent) return;
      lightboxImage.src = images[currentIdx].src;
      lightboxImage.alt = images[currentIdx].alt;
      lightboxCurrent.textContent = currentIdx + 1;
    }
    function close() { lightbox.classList.remove("active"); setTimeout(() => { document.body.style.overflow = ""; }, 300); }
    document.getElementById("lightbox-close")?.addEventListener("click", close, { signal });
    document.getElementById("lightbox-prev")?.addEventListener("click", () => { currentIdx = (currentIdx - 1 + images.length) % images.length; updateImage(); }, { signal });
    document.getElementById("lightbox-next")?.addEventListener("click", () => { currentIdx = (currentIdx + 1) % images.length; updateImage(); }, { signal });
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); }, { signal });
    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("active")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") { currentIdx = (currentIdx + 1) % images.length; updateImage(); }
      if (e.key === "ArrowLeft") { currentIdx = (currentIdx - 1 + images.length) % images.length; updateImage(); }
    }, { signal });
  }
  initHomeLightbox();
  document.addEventListener('astro:page-load', initHomeLightbox);
</script>

<script>
  function setupVideoPreview() {
    document.querySelectorAll('video[data-preview-start]').forEach(video => {
      const v = video as HTMLVideoElement;
      const startAt = parseFloat((v as HTMLElement).dataset.previewStart || '0');
      if (v.readyState >= 1) {
        v.currentTime = startAt;
      } else {
        v.addEventListener('loadedmetadata', () => { v.currentTime = startAt; }, { once: true });
      }
    });
  }
  setupVideoPreview();
  document.addEventListener('astro:page-load', setupVideoPreview);
</script>
