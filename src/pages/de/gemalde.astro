---
import { Image } from "astro:assets";
import PageLayout from "@layouts/PageLayout.astro";
import { getLangFromUrl, useTranslations, getTranslation } from "@utils/i18n";
import { paintings, getPaintingThumbnail, getPaintingFull } from "@utils/paintingsData";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePrefix = lang === "es" ? "" : "/" + lang;

const paintingItems = paintings.map((p) => {
  const thumbnail = getPaintingThumbnail(p.id);
  const full = getPaintingFull(p.id);
  return {
    ...p,
    title: getTranslation(lang, `painting.${p.id}.title`),
    description: getTranslation(lang, `painting.${p.id}.description`),
    thumbnailSrc: thumbnail?.src ?? "",
    fullSrc: full?.src ?? "",
    thumbnail,
    full,
  };
});

const priceLabel = t("paintings.price");
const dimsLabel = t("paintings.dimensions");
const techLabel = t("paintings.technique");
const yearLabel = t("paintings.year");
const acquireLabel = t("paintings.acquire");
const contactCta = t("paintings.contact-cta");
const contactHref = `${basePrefix}/contact`;
---

<PageLayout metadata={{ title: t("paintings.title") }}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold uppercase tracking-widest text-blue-500 dark:text-blue-400 mb-3">
        goldenberry
      </p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight dark:text-white mb-4">
        {t("paintings.title")}
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        {t("paintings.subtitle")}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {
        paintingItems.map((p) =>
          p.thumbnail ? (
            <div
              class="painting-card group cursor-pointer rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700"
              data-full={p.fullSrc}
              data-title={p.title}
              data-description={p.description}
              data-price={p.price}
              data-dimensions={`${p.height} × ${p.width} cm`}
              data-technique={p.technique}
              data-year={p.year}
            >
              <div class="aspect-square overflow-hidden">
                <Image
                  src={p.thumbnail}
                  alt={p.title}
                  width={600}
                  height={600}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-sm text-gray-900 dark:text-white leading-tight mb-2 line-clamp-2">
                  {p.title}
                </h3>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-lg font-bold text-blue-600 dark:text-blue-400">
                    USD {p.price}
                  </span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">
                    {p.year}
                  </span>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 space-y-0.5 mb-3">
                  <p>{p.height} × {p.width} cm</p>
                  <p>{p.technique}</p>
                </div>
                <button
                  class="w-full py-1.5 px-3 text-xs font-medium rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors border border-blue-200 dark:border-blue-700"
                >
                  {acquireLabel}
                </button>
              </div>
            </div>
          ) : null
        )
      }
    </div>

    <div class="mt-14 max-w-3xl mx-auto rounded-xl border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/50 px-6 py-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 dark:text-blue-400 mb-3">
        {t("paintings.manifesto.title")}
      </p>
      <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
        {t("paintings.manifesto.body")}
      </p>
    </div>
  </div>

  <div id="painting-lightbox" class="painting-lightbox-overlay">
    <div class="painting-lightbox-container">
      <button id="plb-close" class="plb-close" aria-label="Schließen">×</button>
      <button id="plb-prev" class="plb-nav plb-prev" aria-label="Vorherige">‹</button>
      <button id="plb-next" class="plb-nav plb-next" aria-label="Nächste">›</button>
      <div class="plb-inner">
        <div class="plb-image-wrap">
          <img id="plb-image" class="plb-image" alt="" />
        </div>
        <div class="plb-info">
          <h2 id="plb-title" class="plb-title"></h2>
          <p id="plb-description" class="plb-description"></p>
          <div class="plb-meta">
            <div class="plb-meta-row">
              <span class="plb-meta-label">{priceLabel}</span>
              <span id="plb-price" class="plb-meta-value plb-price-val"></span>
            </div>
            <div class="plb-meta-row">
              <span class="plb-meta-label">{dimsLabel}</span>
              <span id="plb-dims" class="plb-meta-value"></span>
            </div>
            <div class="plb-meta-row">
              <span class="plb-meta-label">{techLabel}</span>
              <span id="plb-tech" class="plb-meta-value"></span>
            </div>
            <div class="plb-meta-row">
              <span class="plb-meta-label">{yearLabel}</span>
              <span id="plb-year" class="plb-meta-value"></span>
            </div>
          </div>
          <a id="plb-contact" href={contactHref} class="plb-contact-btn">
            {contactCta}
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .painting-lightbox-overlay {
      position: fixed;
      inset: 0;
      background-color: rgba(0, 0, 0, 0);
      z-index: 1000;
      display: flex;
      justify-content: center;
      align-items: center;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }
    .painting-lightbox-overlay.active {
      background-color: rgba(0, 0, 0, 0.92);
      opacity: 1;
      visibility: visible;
    }
    .painting-lightbox-container {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .plb-inner {
      display: flex;
      align-items: flex-start;
      gap: 2rem;
      max-width: 90vw;
      max-height: 90vh;
      transform: scale(0.9);
      opacity: 0;
      transition: all 0.35s ease;
    }
    .painting-lightbox-overlay.active .plb-inner { transform: scale(1); opacity: 1; }
    .plb-image-wrap { flex: 0 0 auto; }
    .plb-image {
      max-width: 55vw;
      max-height: 80vh;
      object-fit: contain;
      border-radius: 8px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.6);
    }
    .plb-info {
      flex: 1;
      min-width: 260px;
      max-width: 320px;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-height: 80vh;
      overflow-y: auto;
      padding-right: 4px;
    }
    .plb-title { font-size: 1.25rem; font-weight: 700; line-height: 1.3; }
    .plb-description { font-size: 0.875rem; line-height: 1.7; color: rgba(255,255,255,0.8); }
    .plb-meta { border-top: 1px solid rgba(255,255,255,0.15); padding-top: 0.75rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .plb-meta-row { display: flex; justify-content: space-between; font-size: 0.8rem; }
    .plb-meta-label { color: rgba(255,255,255,0.5); }
    .plb-meta-value { color: rgba(255,255,255,0.9); font-weight: 500; }
    .plb-price-val { color: #60a5fa; font-weight: 700; font-size: 1rem; }
    .plb-contact-btn {
      display: block; text-align: center; padding: 0.6rem 1rem; background: #2563eb; color: #fff;
      border-radius: 8px; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: background 0.2s; margin-top: auto;
    }
    .plb-contact-btn:hover { background: #1d4ed8; }
    .plb-close {
      position: fixed; top: 24px; right: 28px; background: none; border: none; font-size: 40px;
      color: white; cursor: pointer; z-index: 1001; opacity: 0; transform: translateY(-15px);
      transition: all 0.25s ease 0.1s; line-height: 1;
    }
    .painting-lightbox-overlay.active .plb-close { opacity: 1; transform: translateY(0); }
    .plb-close:hover { color: #f87171; }
    .plb-nav {
      position: fixed; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.1);
      border: none; font-size: 32px; color: white; cursor: pointer; z-index: 1001; width: 48px; height: 48px;
      border-radius: 50%; backdrop-filter: blur(10px); display: grid; place-items: center; opacity: 0; transition: all 0.25s ease 0.15s;
    }
    .painting-lightbox-overlay.active .plb-nav { opacity: 1; }
    .painting-lightbox-overlay.active .plb-nav:hover { background: rgba(255,255,255,0.2); transform: translateY(-50%) scale(1.1); }
    .plb-prev { left: 16px; }
    .plb-next { right: 16px; }
    @media (max-width: 768px) {
      .plb-inner { flex-direction: column; align-items: center; max-width: 92vw; gap: 1rem; padding-bottom: 1rem; }
      .plb-image { max-width: 88vw; max-height: 45vh; }
      .plb-info { min-width: unset; max-width: 88vw; max-height: 35vh; }
      .plb-prev { left: 8px; }
      .plb-next { right: 8px; }
    }
  </style>

  <script>
    let plbAbort: AbortController | null = null;

    function initLightbox() {
      if (plbAbort) plbAbort.abort();
      plbAbort = new AbortController();
      const signal = plbAbort.signal;

      const cards = Array.from(document.querySelectorAll<HTMLElement>('.painting-card'));
      const overlayEl = document.getElementById('painting-lightbox');
      if (!overlayEl || cards.length === 0) return;
      const overlay = overlayEl;

      const img = document.getElementById('plb-image') as HTMLImageElement;
      const titleEl = document.getElementById('plb-title')!;
      const descEl = document.getElementById('plb-description')!;
      const priceEl = document.getElementById('plb-price')!;
      const dimsEl = document.getElementById('plb-dims')!;
      const techEl = document.getElementById('plb-tech')!;
      const yearEl = document.getElementById('plb-year')!;

      let current = 0;

      function update() {
        const d = cards[current].dataset;
        img.src = d.full ?? '';
        img.alt = d.title ?? '';
        titleEl.textContent = d.title ?? '';
        descEl.textContent = d.description ?? '';
        priceEl.textContent = 'USD ' + (d.price ?? '');
        dimsEl.textContent = d.dimensions ?? '';
        techEl.textContent = d.technique ?? '';
        yearEl.textContent = d.year ?? '';
      }

      function openLightbox(index: number) {
        current = index;
        update();
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        overlay.classList.remove('active');
        setTimeout(() => { document.body.style.overflow = ''; }, 300);
      }

      cards.forEach((card, i) => {
        card.addEventListener('click', () => openLightbox(i), { signal });
      });

      document.getElementById('plb-close')!.addEventListener('click', closeLightbox, { signal });
      document.getElementById('plb-prev')!.addEventListener('click', () => {
        current = (current - 1 + cards.length) % cards.length;
        update();
      }, { signal });
      document.getElementById('plb-next')!.addEventListener('click', () => {
        current = (current + 1) % cards.length;
        update();
      }, { signal });

      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeLightbox();
      }, { signal });

      document.addEventListener('keydown', (e) => {
        if (!overlay.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') { current = (current + 1) % cards.length; update(); }
        if (e.key === 'ArrowLeft') { current = (current - 1 + cards.length) % cards.length; update(); }
      }, { signal });
    }

    initLightbox();
    document.addEventListener('astro:page-load', initLightbox);
  </script>
</PageLayout>
