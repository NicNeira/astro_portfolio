---
import type { CallToAction, Widget } from "@utils/types";
import Button from "@components/ui/Button.astro";

interface Props extends Widget {
  title?: string;
  subtitle?: string;
  tagline?: string;
  callToAction?: CallToAction;
  actions?: string | CallToAction[];
}

const {
  title = await Astro.slots.render("title"),
  subtitle = await Astro.slots.render("subtitle"),
  actions = await Astro.slots.render("actions"),
  id,
} = Astro.props;
---

<section
  id={id}
  class="relative scroll-mt-[72px]"
  style="background: rgba(11,9,8,0.85);"
>
  <div
    class="mx-auto px-6 md:px-16 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    style="max-width: 1440px; padding-top: 80px; padding-bottom: 80px;"
  >
    <div
      class="text-center"
      style="border-top: 1px solid #2C2620; padding-top: 56px;"
    >
      {title && (
        <h2
          class="serif"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 600; color: #E8E0D2; margin: 0 0 12px;"
          set:html={title}
        />
      )}
      {subtitle && (
        <p
          style="font-size: 0.875rem; color: #847B6F; margin: 0 0 28px;"
          set:html={subtitle}
        />
      )}
      {actions && (
        <div class="flex justify-center gap-4 flex-wrap">
          {Array.isArray(actions) ? (
            actions.map((action) => (
              <Button {...(action || {})} variant={action.variant || "primary"} />
            ))
          ) : (
            <Fragment set:html={actions} />
          )}
        </div>
      )}
    </div>
  </div>
</section>
