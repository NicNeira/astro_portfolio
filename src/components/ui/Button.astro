---
import { Icon } from "astro-icon/components";
import { twMerge } from "tailwind-merge";

import type { CallToAction as Props } from "@utils/types";

type VariantType = "primary" | "secondary" | "tertiary" | "link";

const {
  variant = "secondary",
  target,
  icon = "",
  class: className = "",
  type,
  href,
  text,
  ...rest
} = Astro.props as Props & { variant?: VariantType };

const commonButtonStyles =
  "py-3 px-7 rounded font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-200 inline-flex items-center justify-center text-center gap-x-1.5 text-sm";

const variantsClasses = {
  primary:   `${commonButtonStyles} bg-[#D4AF37] text-white hover:bg-[#E0C040] hover:shadow-[0_4px_16px_rgba(212,175,55,0.3)] hover:-translate-y-px focus:ring-[#D4AF37]`,
  secondary: `${commonButtonStyles} bg-transparent text-[#847B6F] border border-[#2C2620] hover:text-[#E8E0D2] hover:border-[#5E574E] focus:ring-[#2C2620]`,
  tertiary:  `${commonButtonStyles} bg-transparent text-[#D4AF37] border border-[#D4AF37] hover:bg-[#D4AF37] hover:text-white focus:ring-[#D4AF37]`,
  link:      "text-[#D4AF37] hover:text-[#E0C040] hover:underline focus:outline-none focus:ring-1 focus:ring-[#D4AF37] rounded-sm inline-flex items-center text-center gap-x-1.5",
};

const isButtonElement =
  type === "button" || type === "submit" || type === "reset";
const Tag = isButtonElement ? "button" : "a";

let tagSpecificProps: Record<string, any> = {};
if (isButtonElement) {
  tagSpecificProps.type = type;
} else {
  tagSpecificProps.href = href;
  if (target) {
    tagSpecificProps.target = target;
    if (target === "_blank") {
      tagSpecificProps.rel = "noopener noreferrer";
    }
  }
}

const finalClass = twMerge(
  variantsClasses[variant as keyof typeof variantsClasses] || variantsClasses.secondary,
  className
);
---

<Tag class={finalClass} {...tagSpecificProps} {...rest}>
  {text ? text : <slot />}
  {icon && <Icon name={icon} class:list={["w-5 h-5", "shrink-0"]} />}
</Tag>
