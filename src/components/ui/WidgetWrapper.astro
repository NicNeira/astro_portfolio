---
import type { HTMLTag } from "astro/types";
import type { Widget } from "@utils/types";
import { twMerge } from "tailwind-merge";

export interface Props extends Widget {
  containerClass?: string;
  ["as"]?: HTMLTag;
}

const {
  id,
  isDark = false,
  containerClass = "",
  bg,
  as = "section",
} = Astro.props;

const WrapperTag = as;
---

<WrapperTag
  class="relative not-prose scroll-mt-[72px]"
  style="background: rgba(11,9,8,0.85);"
  {...id ? { id } : {}}
>
  {(bg || isDark) && (
    <div class="absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true">
      <slot name="bg">
        {bg ? <Fragment set:html={bg} /> : null}
      </slot>
    </div>
  )}
  <div
    class={twMerge(
      "relative mx-auto max-w-7xl px-6 md:px-16 py-12 md:py-16 intersect-once intersect-quarter intercept-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade",
      containerClass
    )}
    style="color: #E8E0D2;"
  >
    <slot />
  </div>
</WrapperTag>
