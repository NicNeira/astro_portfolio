---
// Componente de fondo animado con shader WebGL2
---

<canvas
  id="animated-background"
  style="position:fixed;inset:0;width:100%;height:100%;z-index:0;opacity:0.08;pointer-events:none;"
  transition:persist
></canvas>

<script>
  import AnimatedBackground from "../../scripts/animated-background.js";

  declare global {
    interface Window {
      backgroundInstance: any;
    }
  }

  if (typeof window !== "undefined") {
    // Asegurarnos de que solo haya una instancia
    if (!window.backgroundInstance) {
      window.backgroundInstance = new AnimatedBackground();
      window.backgroundInstance.start();
    }
  }
</script>
