---
import { twMerge } from "tailwind-merge";
import type { Item } from "@utils/types";

export interface Props {
  items?: Array<Item>;
  defaultIcon?: string;
  classes?: Record<string, string>;
}

const { items = [], classes = {} } = Astro.props as Props;
const { container: containerClass = "" } = classes;
---

{items && items.length > 0 && (
  <div class={twMerge("relative pl-8", containerClass)} style="border-left: 1px solid #2C2620; margin-left: 6px;">
    {items.map(({ title, description }, index) => (
      <div
        class="relative pb-10 last:pb-0 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade timeline-item"
        style={`animation-delay: ${index * 0.08}s;`}
      >
        <!-- Dot -->
        <div
          class="absolute timeline-dot"
          style={`left: -37px; top: 6px; width: 11px; height: 11px; border-radius: 50%; background: ${index === 0 ? '#D4AF37' : '#1A1714'}; border: 2px solid #D4AF37; transition: box-shadow 0.3s;`}
        ></div>

        {title && (
          <p
            class="text-base font-semibold leading-tight mb-1 serif"
            style="color: #E8E0D2; font-size: 1.25rem;"
            set:html={title}
          />
        )}
        {description && (
          <p
            class="mt-2 leading-relaxed"
            style="color: #847B6F; font-size: 0.9375rem;"
            set:html={description}
          />
        )}
      </div>
    ))}
  </div>
)}

<style>
  .timeline-item:hover .timeline-dot {
    box-shadow: 0 0 12px rgba(212,175,55,0.4);
  }
</style>
