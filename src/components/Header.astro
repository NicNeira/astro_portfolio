---
import LanguageSelector from "../components/common/LanguageSelector.astro";
import Button from "../components/ui/Button.astro";
import { trimSlash } from "../utils/utils.js";
import ToggleMenu from "./common/ToggleMenu.astro";
import Logo from "./Logo.astro";
import { getLangFromUrl, defaultLang, languages } from "../utils/i18n";

interface ActionLink {
  text: string;
  href: string;
  variant?: "primary" | "secondary" | "tertiary" | "link";
  icon?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  type?: "button" | "submit" | "reset";
  class?: string;
}

interface MenuLink {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<ActionLink>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = "header",
  links = [],
  actions = [],
  isSticky = false,
  isFullWidth = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const currentLang = getLangFromUrl(Astro.url);

function getHomeUrl(lang: string) {
  return lang === defaultLang ? "/" : `/${lang}/`;
}

const pageSlugMap: Record<string, Record<string, string>> = {
  pinturas:  { es: 'pinturas', en: 'paintings', de: 'gemalde' },
  paintings: { es: 'pinturas', en: 'paintings', de: 'gemalde' },
  gemalde:   { es: 'pinturas', en: 'paintings', de: 'gemalde' },
};

function getMobileLangPath(lang: string, path: string) {
  const segments = path.split('/').filter(Boolean);
  if (segments[0] && segments[0] in languages) segments.shift();
  const mapped = segments.map(seg => pageSlugMap[seg]?.[lang] ?? seg);
  if (lang === 'es') return mapped.length ? '/' + mapped.join('/') : '/';
  return mapped.length ? `/${lang}/` + mapped.join('/') : `/${lang}`;
}

function getLangFlag(lang: string) {
  const flags: Record<string, string> = { es: '🇪🇸', en: '🇺🇸', de: '🇩🇪' };
  return flags[lang] || '🌐';
}
---

<header
  id={id}
  class="fixed top-0 left-0 right-0 z-50 w-full transition-all duration-300 ease-in-out"
  style="background: rgba(11,9,8,0.92); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-bottom: 1px solid transparent;"
  {...isSticky ? { "data-aw-sticky-header": true } : {}}
>
  <div
    class:list={[
      "mx-auto px-6 md:px-16",
      { "max-w-[1440px]": !isFullWidth },
    ]}
  >
    <div class="flex items-center justify-between" style="height: 68px;">
      <!-- Logo -->
      <a
        href={getHomeUrl(currentLang)}
        class="flex items-center"
        aria-label="Ir al inicio"
      >
        <Logo />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center" style="gap: 28px;">
        {
          links.map(({ text, href }) => (
            <a
              href={href}
              class="nav-link text-sm transition-colors duration-200"
              style={`font-weight: ${href === currentPath ? 500 : 400}; color: ${href === currentPath ? '#E8E0D2' : '#847B6F'};`}
            >
              {text}
            </a>
          ))
        }
      </nav>

      <!-- Desktop Actions -->
      <div class="hidden md:flex items-center" style="gap: 16px;">
        {
          actions.map((action) => (
            <a
              href={action.href}
              class="contact-btn text-sm font-medium transition-all duration-200"
              style="color: #fff; background: #D4AF37; padding: 8px 24px; border-radius: 4px; text-decoration: none;"
            >
              {action.text}
            </a>
          ))
        }
        <LanguageSelector />
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center gap-3">
        <LanguageSelector />
        <ToggleMenu />
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden"
    style="background: rgba(11,9,8,0.98); backdrop-filter: blur(20px); border-top: 1px solid #2C2620;"
  >
    <div class="px-6 py-6 space-y-1">
      {
        links.map(({ text, href }) => (
          <a
            href={href}
            class="block py-3 text-sm text-center border-b transition-colors duration-200"
            style={`color: ${href === currentPath ? '#D4AF37' : '#847B6F'}; border-color: #2C2620;`}
          >
            {text}
          </a>
        ))
      }
      {
        actions.map((action) => (
          <a
            href={action.href}
            class="block mt-4 py-3 text-center text-sm font-medium rounded"
            style="background: #D4AF37; color: #fff; text-decoration: none;"
          >
            {action.text}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  function initializeHeader() {
    const header = document.getElementById("header");
    const toggleButton = document.querySelector("[data-aw-toggle-menu]");
    const mobileMenu = document.getElementById("mobile-menu");

    function updateHeaderOnScroll() {
      if (!header) return;
      if (window.scrollY > 30) {
        header.style.borderBottomColor = "#2C2620";
      } else {
        header.style.borderBottomColor = "transparent";
      }
    }

    updateHeaderOnScroll();
    window.addEventListener("scroll", updateHeaderOnScroll, { passive: true });

    if (toggleButton && mobileMenu) {
      mobileMenu.classList.add("hidden");
      toggleButton.setAttribute("aria-expanded", "false");

      toggleButton.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isHidden = mobileMenu.classList.contains("hidden");
        if (isHidden) {
          mobileMenu.classList.remove("hidden");
          toggleButton.setAttribute("aria-expanded", "true");
          document.body.style.overflow = "hidden";
        } else {
          mobileMenu.classList.add("hidden");
          toggleButton.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        }
      });
    }

    const mobileLinks = mobileMenu?.querySelectorAll("a");
    mobileLinks?.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu?.classList.add("hidden");
        toggleButton?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      });
    });

    // Smooth scroll for hash links on the same page
    document.querySelectorAll('a[href*="#"]').forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (!href) return;
        const url = new URL(href, window.location.origin);
        const hash = url.hash;
        if (!hash) return;
        // Only handle if navigating to current page or root with hash
        const isCurrentPage = url.pathname === window.location.pathname ||
          (url.pathname === '/' && window.location.pathname === '/') ||
          url.pathname + '/' === window.location.pathname ||
          window.location.pathname + '/' === url.pathname;
        if (isCurrentPage || url.pathname.replace(/\/$/, '') === window.location.pathname.replace(/\/$/, '')) {
          const target = document.querySelector(hash);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: "smooth", block: "start" });
            history.pushState(null, "", hash);
          }
        }
      });
    });

    setTimeout(() => {
      document.addEventListener("click", (e) => {
        if (toggleButton?.contains(e.target as Node)) return;
        if (mobileMenu && !mobileMenu.contains(e.target as Node) && !mobileMenu.classList.contains("hidden")) {
          mobileMenu.classList.add("hidden");
          toggleButton?.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        }
      });
    }, 100);

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768 && mobileMenu && !mobileMenu.classList.contains("hidden")) {
        mobileMenu.classList.add("hidden");
        toggleButton?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }
    });
  }

  function cleanupHeader() {
    const mobileMenu = document.getElementById("mobile-menu");
    const toggleButton = document.querySelector("[data-aw-toggle-menu]");
    if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
      mobileMenu.classList.add("hidden");
      toggleButton?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }
  }

  // astro:page-load fires on initial load AND on every navigation with ClientRouter.
  // Using only this event prevents the double-init that caused the menu to be
  // unresponsive on first load (DOMContentLoaded + astro:page-load ran initializeHeader
  // twice, attaching two click handlers that toggled each other immediately).
  document.addEventListener("astro:page-load", () => {
    cleanupHeader();
    initializeHeader();
  });

  document.addEventListener("astro:before-preparation", cleanupHeader);
</script>

<style>
  header { display: block !important; visibility: visible !important; }

  .nav-link:hover { color: #E8E0D2 !important; }

  .contact-btn:hover {
    background: #E0C040 !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(212,175,55,0.3);
  }

  #mobile-menu.hidden { display: none; }
  #mobile-menu:not(.hidden) { display: block !important; animation: slideDown 0.25s ease; }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (min-width: 768px) {
    #mobile-menu { display: none !important; }
    [data-aw-toggle-menu] { display: none !important; }
  }
</style>
