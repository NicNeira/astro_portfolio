---
const {
  title = await Astro.slots.render("title"),
  subtitle = await Astro.slots.render("subtitle"),
  image,
  paragraph = await Astro.slots.render("paragraph"),
  actions = await Astro.slots.render("actions"),
  id,
} = Astro.props;

const isImageObject = typeof image === "object" && image !== null && (image as any).src;
---

<section
  id={id}
  class="relative overflow-hidden"
  style="min-height: 100vh;"
>
  <!-- Background Image -->
  <div
    class="absolute inset-0 z-0"
    style="background-image: url('https://res.cloudinary.com/ds8bhx4d4/image/upload/v1779480705/Multimedia_oygnl3.jpg'); background-size: cover; background-position: center;"
  ></div>
  <div class="absolute inset-0 z-0" style="background: rgba(11,9,8,0.75);"></div>

  <!-- Content -->
  <div
    class="relative z-10 mx-auto px-6 md:px-16"
    style="max-width: 1440px;"
  >
    <!-- Nav spacer -->
    <div style="padding-top: 68px;"></div>

    <div
      class="flex flex-col lg:flex-row items-center lg:items-center justify-between"
      style="min-height: calc(100vh - 68px); padding: 60px 0 80px; gap: 48px;"
    >
      <!-- Left: Text -->
      <div style="max-width: 700px; flex: 1;" class="hero-text">
        <span class="accent-line mb-6 block hero-reveal" style="animation-delay: 0s;"></span>

        {title && (
          <h1
            class="serif hero-reveal"
            style="font-size: clamp(3.5rem, 6vw, 5.5rem); font-weight: 600; line-height: 0.95; margin: 0 0 20px; letter-spacing: -0.01em; color: #E8E0D2; animation-delay: 0.1s;"
            set:html={title}
          />
        )}

        {subtitle && (
          <p
            class="hero-reveal"
            style="font-size: 1rem; letter-spacing: 0.08em; color: #C47D3F; margin: 0 0 24px; font-weight: 400; animation-delay: 0.2s;"
            set:html={subtitle}
          />
        )}

        {paragraph && (
          <p
            class="hero-reveal"
            style="font-size: 0.9375rem; line-height: 1.8; color: #847B6F; max-width: 520px; margin: 0 0 36px; animation-delay: 0.3s;"
          >
            <slot name="paragraph" />
          </p>
        )}

        {actions && (
          <div
            class="flex gap-4 flex-wrap hero-reveal"
            style="animation-delay: 0.4s;"
          >
            <slot name="actions" />
          </div>
        )}
      </div>

      <!-- Right: Profile Photo -->
      {isImageObject && (
        <div
          class="hero-reveal flex justify-center lg:justify-end"
          style="flex: 0 0 auto; animation-delay: 0.3s;"
        >
          <div
            style="width: clamp(260px, 22vw, 340px); height: clamp(340px, 28vw, 440px); overflow: hidden; border-radius: 6px; box-shadow: 0 30px 60px rgba(0,0,0,0.5);"
          >
            <img
              src={(image as any).src}
              alt={(image as any).alt || ""}
              width={(image as any).width || 600}
              height={(image as any).height || 800}
              class="w-full h-full object-cover object-top"
              style="filter: grayscale(15%);"
              loading="eager"
              transition:name="hero-portrait"
            />
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-reveal {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeInUp 0.7s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Ensure reveals fire on page transitions too */
  @media (prefers-reduced-motion: reduce) {
    .hero-reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
