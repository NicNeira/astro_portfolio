---
import { languages, getLangFromUrl } from "@utils/i18n";

const currentLang = getLangFromUrl(Astro.url);

const flagSVG: Record<string, string> = {
  es: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="13" viewBox="0 0 20 13" style="border-radius:2px;display:block;"><rect width="20" height="13" fill="#D52B1E"/><rect width="20" height="6.5" fill="#fff"/><rect width="6.5" height="6.5" fill="#0039A6"/><polygon points="3.25,1.45 3.67,2.67 4.96,2.69 3.93,3.47 4.31,4.71 3.25,3.97 2.19,4.71 2.57,3.47 1.54,2.69 2.83,2.67" fill="#fff"/></svg>`,
  en: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="11" viewBox="0 0 20 11" style="border-radius:2px;display:block;"><rect width="20" height="11" fill="#B22234"/><rect y="0.85" width="20" height="0.85" fill="#fff"/><rect y="2.54" width="20" height="0.85" fill="#fff"/><rect y="4.23" width="20" height="0.85" fill="#fff"/><rect y="5.92" width="20" height="0.85" fill="#fff"/><rect y="7.62" width="20" height="0.85" fill="#fff"/><rect y="9.31" width="20" height="0.85" fill="#fff"/><rect width="7.69" height="5.92" fill="#3C3B6E"/></svg>`,
  de: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="12" viewBox="0 0 5 3" style="border-radius:2px;display:block;"><rect width="5" height="1" fill="#000"/><rect y="1" width="5" height="1" fill="#DD0000"/><rect y="2" width="5" height="1" fill="#FFCE00"/></svg>`,
};
const currentPath = Astro.url.pathname;

const pageSlugMap: Record<string, Record<string, string>> = {
  'pinturas':  { es: 'pinturas', en: 'paintings', de: 'gemalde' },
  'paintings': { es: 'pinturas', en: 'paintings', de: 'gemalde' },
  'gemalde':   { es: 'pinturas', en: 'paintings', de: 'gemalde' },
};

function getLocalizedPath(lang: string, currentPath: string) {
  const segments = currentPath.split('/').filter(Boolean);
  // Quitar prefijo de idioma si existe
  if (segments[0] && segments[0] in languages) segments.shift();
  // Mapear slugs conocidos a su equivalente en el idioma destino
  const mapped = segments.map(seg => pageSlugMap[seg]?.[lang] ?? seg);
  if (lang === 'es') {
    return mapped.length ? '/' + mapped.join('/') : '/';
  }
  return mapped.length ? `/${lang}/` + mapped.join('/') : `/${lang}`;
}
---

<div class="relative inline-block text-left">
  <button
    type="button"
    class="lang-btn flex items-center justify-center rounded-full transition-all duration-200 focus:outline-none"
    id="language-menu"
    aria-expanded="false"
    aria-haspopup="true"
    aria-label="Change language"
    style="width: 36px; height: 36px; background: transparent; border: 1px solid #2C2620;"
  >
    <Fragment set:html={flagSVG[currentLang]} />
  </button>

  <div
    class="origin-top-right absolute right-0 mt-2 w-40 rounded-md shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden"
    id="language-dropdown"
    role="menu"
    aria-orientation="vertical"
    aria-labelledby="language-menu"
    tabindex="-1"
    style="background: #1A1714; border: 1px solid #2C2620;"
  >
    <div class="py-1" role="none">
      {
        Object.entries(languages).map(([lang, name]) => (
          <a
            href={getLocalizedPath(lang, currentPath)}
            class={`group flex items-center px-4 py-2 text-sm transition-colors`}
            role="menuitem"
            tabindex="-1"
            style={currentLang === lang ? "color: #E8E0D2; background: #2C2620;" : "color: #847B6F;"}
          >
            <span class="mr-3" set:html={flagSVG[lang]} />
            {name}
            {currentLang === lang && (
              <span class="ml-auto">
                <svg
                  class="h-4 w-4"
                  style="color: #C47D3F;"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
            )}
          </a>
        ))
      }
    </div>
  </div>
</div>

<script>
  let lsAbort: AbortController | null = null;
  function initLanguageSelector() {
    if (lsAbort) lsAbort.abort();
    lsAbort = new AbortController();
    const { signal } = lsAbort;
    const button = document.getElementById("language-menu");
    const dropdown = document.getElementById("language-dropdown");
    if (!button || !dropdown) return;
    button.addEventListener("click", () => {
      dropdown.classList.toggle("hidden", !dropdown.classList.contains("hidden"));
    }, { signal });
    document.addEventListener("click", (event) => {
      if (!button.contains(event.target as Node) && !dropdown.contains(event.target as Node))
        dropdown.classList.add("hidden");
    }, { signal });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") dropdown.classList.add("hidden");
    }, { signal });
  }
  initLanguageSelector();
  document.addEventListener("astro:page-load", initLanguageSelector);
</script>

<style>
  .lang-btn:hover { border-color: #5E574E; background: rgba(44,38,32,0.5) !important; }
  [role="menuitem"]:hover { background: #2C2620; color: #E8E0D2 !important; }
</style>

